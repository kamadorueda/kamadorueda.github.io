---
type Props = {
  title: string;
  ogTitle?: string;
  description?: string;
};

const { title, ogTitle, description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {ogTitle && <meta content={ogTitle} name="og:title" />}
    {description && <meta content={description} name="og:description" />}
    {description && <meta content="website" name="og:type" />}
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700&display=swap"
      rel="stylesheet"
      crossorigin
    />
    <link
      rel="icon"
      href="https://avatars.githubusercontent.com/u/47480384?v=4"
      type="image/x-icon"
    />
    <script is:inline src="https://www.youtube.com/iframe_api"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
