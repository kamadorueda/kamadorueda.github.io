---
import Html from "~/components/Html/index.astro";
import { Body } from "~/components/Body";
import { Main } from "~/components/Main";
import { YoutubeVideo } from "~/components/YoutubeVideo";
import "~/index.css";
---

<Html title="YouTube Test">
  <Body>
    <Main>
      <div style="padding: 2rem;">
        <h1>YouTube Player Test</h1>

        <h2 style="margin-top: 2rem;">Video 1</h2>
        <YoutubeVideo
          client:load
          highlight={{ from: [0, 0], to: [10, 0] }}
          sectionLabel="Test Video 1"
          videoId="dQw4w9WgXcQ"
        />

        <h2 style="margin-top: 2rem;">Video 2</h2>
        <YoutubeVideo
          client:load
          highlight={{ from: [0, 0], to: [15, 0] }}
          sectionLabel="Test Video 2"
          videoId="jNQXAC9IVRw"
        />
      </div>
    </Main>
  </Body>
</Html>
